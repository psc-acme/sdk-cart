{
    "name": "psc-acme/sdk-cart",
    "description": "Package sdk-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\SdkCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/cache": "^7.0",
        "symfony/http-foundation": "^7.0",
        "doctrine/orm": "^3.0",
        "symfony/dotenv": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/phpunit-bridge": "^7.0",
        "fakerphp/faker": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}